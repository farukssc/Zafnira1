rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Default-deny Catch-all Gate
    match /{document=**} {
      allow read, write: if false;
    }

    // Shared Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isEmailVerified() {
      return isSignedIn() && (request.auth.token.email_verified == true || request.auth.token.firebase.sign_in_provider == 'google.com');
    }

    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email == "farukbangla53@gmail.com" ||
        exists(/databases/$(database)/documents/admins/$(request.auth.uid))
      );
    }

    function isValidId(id) {
       return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-\\.\\s=]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // Categories
    match /categories/{categoryId} {
      allow read: if true;
      allow write: if isAdmin() && isValidId(categoryId);
    }

    // Products
    match /products/{productId} {
      allow read: if true;
      allow write: if isAdmin() && isValidId(productId);
    }

    // Coupons
    match /coupons/{couponId} {
      allow read: if true;
      allow write: if isAdmin() && isValidId(couponId);
    }

    // Popups
    match /popups/{popupId} {
      allow read: if true;
      allow write: if isAdmin() && isValidId(popupId);
    }

    // CMS Configuration (Global Pages, Banner Settings, Navigation Links)
    match /cms_config/{configId} {
      allow read: if true;
      allow write: if isAdmin() && isValidId(configId);
    }

    // Orders Collection Rules
    match /orders/{orderId} {
      allow create: if isSignedIn() && isValidId(orderId) && incoming().userId == request.auth.uid;
      allow get: if isSignedIn() && isValidId(orderId) && (existing().userId == request.auth.uid || isAdmin());
      allow list: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow update: if isSignedIn() && isValidId(orderId) && (
        isAdmin() || 
        (existing().userId == request.auth.uid && incoming().status == "cancelled" && existing().status == "pending" && incoming().diff(existing()).affectedKeys().hasOnly(['status']))
      );
      allow delete: if isAdmin() && isValidId(orderId);
    }

    // Admins Collection
    match /admins/{adminId} {
      allow read: if isSignedIn();
      allow write: if isAdmin() && isValidId(adminId);
    }
  }
}
